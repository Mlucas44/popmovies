{# page--user--login.html.twig #}
<div class="min-h-screen bg-pop-nuit text-pop-blanc flex flex-col font-sans selection:bg-pop-or selection:text-pop-nuit">

	<header class="bg-pop-nuit/50 backdrop-blur-xl sticky top-0 z-50 border-b border-pop-toile shadow-[0_4px_30px_rgba(0,0,0,0.5)]">
		<div class="container mx-auto">
			{{ page.header }}
		</div>
	</header>

	<main class="flex-grow w-full flex flex-col justify-center items-center px-4 py-12">
		<div class="w-full max-w-md bg-pop-toile shadow-[0_8px_30px_rgba(0,0,0,0.6)] border border-pop-nuit rounded-2xl p-8">

			<div class="flex border-b border-pop-mute/20 mb-8">
				<a href="/user/login" class="flex-1 text-center py-3 border-b-2 border-pop-rouge text-pop-rouge font-semibold transition-colors">
					Connexion
				</a>
				<a href="/user/register" class="flex-1 text-center py-3 border-b-2 border-transparent text-pop-mute hover:text-pop-blanc transition-colors">
					S'inscrire
				</a>
			</div>

			<h2 class="text-2xl font-bold text-pop-blanc mb-6 text-center">Bon retour sur PopMovie</h2>

			<div class="user-auth-form [&_.password-strength]:!hidden [&_.password-suggestions]:!hidden [&_.password-confirm-message]:!hidden">
				{{ page.content }}
			</div>
		</div>
	</main>
	{% include '@tmdb_theme/includes/footer.html.twig' %}
</div>
