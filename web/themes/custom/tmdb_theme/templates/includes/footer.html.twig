<footer class="bg-pop-toile border-t border-pop-blanc/5 pt-8 pb-8 mt-24 relative overflow-hidden">
  {# Effet de lueur en arrière-plan du footer #}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-1 bg-pop-or/20 blur-2xl"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="mb-12 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      {# Partie Gauche (Logo, description, réseaux) #}
      <div class="lg:col-span-5 flex flex-col items-center lg:items-start text-center lg:text-left space-y-4">
         {{ page.footer_left }}
      </div>
      
      {# Espace vide au milieu pour aérer et équilibrer #}
      <div class="hidden lg:block lg:col-span-4"></div>

      {# Partie Droite (Liens légaux / navigation) #}
      <div class="pt-4 lg:col-span-3 flex flex-col items-center lg:items-start text-center lg:text-left space-y-4">
         {{ page.footer_right }}
      </div>
    </div>
    <div class="pt-8 border-t border-pop-blanc/5 text-xs text-pop-mute flex flex-col md:flex-row justify-between items-center gap-6">
      
      {# Gauche : Copyright dynamique #}
      <p class="text-center md:text-left">
        &copy; {{ 'now'|date('Y') }} {{ 'PopMovie. Tous droits réservés.'|t }}
      </p>

      {# Droite : Attribution légale TMDB #}
      <div class="flex flex-col md:flex-row items-center gap-3">
        <p class="text-center md:text-right max-w-xs md:max-w-md">
          {{ "Ce produit utilise l'API TMDB mais n'est ni approuvé ni certifié par TMDB."|t }}
        </p>
        {# Logo officiel TMDB (chargé depuis leur serveur) #}
        <a href="https://www.themoviedb.org/" target="_blank" rel="noopener noreferrer">
          <img src="https://www.themoviedb.org/assets/2/v4/logos/v2/blue_short-8e7b30f73a4020692ccca9c88bafe5dcb6f8a62a4c6bc55cd9ba82bb2cd95f6c.svg" alt="{{ 'TMDB Logo'|t }}" class="h-3 w-auto opacity-70 hover:opacity-100 transition-opacity duration-300">
        </a>
      </div>

    </div>
  </div>
</footer>