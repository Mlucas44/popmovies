{# web/themes/custom/tmdb_theme/templates/menu--footer-right.html.twig #}
{% import _self as menus %}

<div class="w-full">
  {# Titre stylisé #}
  <h3 class="text-pop-blanc font-bold text-lg mb-6 relative inline-block">
    Informations & Légal
    <span class="absolute -bottom-2 left-0 w-1/3 h-1 bg-pop-or rounded-full"></span>
  </h3>
  
  {{ menus.menu_links(items, attributes, 0) }}
</div>

{% macro menu_links(items, attributes, menu_level) %}
  {% if items %}
    <ul class="flex flex-col gap-4 text-sm md:text-base text-pop-mute">
      {% for item in items %}
        <li class="group">
          {# L'effet hover fait apparaître un chevron à gauche des liens #}
          <a href="{{ item.url }}" class="flex items-center justify-center lg:justify-start hover:text-pop-blanc transition-colors duration-300">
            <span class="text-pop-or mr-2 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </span>
            <span class="transform group-hover:translate-x-1 transition-transform duration-300">{{ item.title }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}