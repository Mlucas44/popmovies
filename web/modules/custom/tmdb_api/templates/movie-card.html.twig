<a
	href="/film/{{ movie.id }}" class="block w-full h-full relative group">

	{# Film perforations OUTSIDE the card (left) #}
	<div class="absolute -left-3 md:-left-4 top-0 bottom-0 w-3 md:w-4 bg-pop-nuit border-y border-l border-white/10 flex flex-col justify-evenly items-center z-10 transition-all duration-300 group-hover:-translate-y-1">
		{% for i in 1..8 %}
			<div class="w-2 h-3 md:w-2 md:h-3 rounded-[2px] bg-white "></div>
		{% endfor %}
	</div>

	{# Film perforations OUTSIDE the card (right) #}
	<div class="absolute -right-3 md:-right-4 top-0 bottom-0 w-3 md:w-4 bg-pop-nuit border-y border-r border-white/10 flex flex-col justify-evenly items-center z-10 transition-all duration-300 group-hover:-translate-y-1">
		{% for i in 1..8 %}
			<div class="w-2 h-3 md:w-2 md:h-3 rounded-[2px] bg-white "></div>
		{% endfor %}
	</div>

	{# Main Poster Card (Untouched aspect ratio) #}
	<div
		class="relative aspect-[2/3] h-full overflow-hidden bg-pop-nuit border-y border-white/10 z-20 shadow-[0_12px_28px_rgba(0,0,0,0.65)] transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_18px_38px_rgba(0,0,0,0.75)]">

		{# Poster window - Full width and height ! #}
		<div class="absolute inset-0 w-full h-full bg-pop-nuit">
			{% if movie.poster_path %}
				<img class="absolute inset-0 w-full h-full object-cover saturate-[1.2] contrast-[1.05] brightness-[1.05] transition-transform duration-500 group-hover:scale-[1.02]" src="https://image.tmdb.org/t/p/w500{{ movie.poster_path }}" alt="{{ movie.title }}">
			{% else %}
				<div class="absolute inset-0 w-full h-full bg-pop-nuit flex items-center justify-center text-pop-mute px-2 text-center text-xs font-typewriter">
					<span>Poster unavailable</span>
				</div>
			{% endif %}

			{# Subtle cinematic overlays #}
			<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
			<div class="absolute inset-x-0 top-0 h-10 bg-gradient-to-b from-white/15 to-transparent"></div>
		</div>
	</div>
</a>
