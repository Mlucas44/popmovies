<a href="/film/{{ movie.id }}" class="block w-full h-full">
  <div class="group relative rounded-xl overflow-hidden bg-white/5 border border-pop-toile backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_10px_40px_rgba(0,0,0,0.8)] hover:border-white/20 cursor-pointer flex flex-col aspect-[2/3] h-full">
    {% if movie.poster_path %}
      <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://image.tmdb.org/t/p/w500{{ movie.poster_path }}" alt="{{ movie.title }}">
    {% else %}
      <div class="absolute inset-0 w-full h-full bg-gray-900 flex items-center justify-center text-gray-600 px-2 text-center text-sm">
        <span>Affiche indisponible</span>
      </div>
    {% endif %}
    <div class="absolute top-3 right-3 bg-black/50 backdrop-blur-md border border-pop-toile text-pop-or px-2 py-1 rounded-lg text-xs font-bold flex items-center gap-1 shadow-lg">
      <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      {{ movie.vote_average ? movie.vote_average|number_format(1) : '0.0' }}
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"></div>
    <div class="relative mt-auto p-4 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
      <h3 class="text-white font-bold text-base md:text-lg leading-tight line-clamp-2 mb-1" title="{{ movie.title }}">{{ movie.title }}</h3>
      {% if movie.release_date %}
        <div class="text-pop-blanc/60 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100">Sortie : {{ movie.release_date|date("Y") }}</div>
      {% endif %}
    </div>
  </div>
</a>