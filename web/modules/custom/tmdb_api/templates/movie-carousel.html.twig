<div class="mb-12">
	<h2 class="text-2xl md:text-3xl font-bold text-white mb-6">{{ title }}</h2>
	<div
		class="relative js-carousel-wrapper">
		{# Flèche Gauche #}
		<button class="js-carousel-prev hidden absolute -left-2 md:-left-8 lg:-left-12 top-[40%] -translate-y-1/2 z-20 bg-black/80 hover:bg-pop-or text-white p-3 rounded-full backdrop-blur-md shadow-[0_4px_15px_rgba(0,0,0,0.5)] border border-white/10 transition-all focus:outline-none">
			<svg class="w-6 h-6" viewbox="0 0 24 24" fill="none">
				<path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>

		<div class="js-carousel-container flex overflow-x-auto snap-x snap-mandatory gap-2 md:gap-4 pt-4 pb-8 px-4 md:px-6 -mx-2 hide-scrollbar relative">
			{% for movie in movies %}
				<div class="snap-start shrink-0 w-44 md:w-60 px-4 md:px-6 py-4">
					{% include '@tmdb_api/movie-card.html.twig' with {'movie': movie} %}
				</div>
			{% endfor %}
		</div>

		{# Flèche Droite #}
		<button class="js-carousel-next absolute -right-2 md:-right-8 lg:-right-12 top-[40%] -translate-y-1/2 z-20 bg-black/80 hover:bg-pop-or text-white p-3 rounded-full backdrop-blur-md shadow-[0_4px_15px_rgba(0,0,0,0.5)] border border-white/10 transition-all focus:outline-none">
			<svg class="w-6 h-6" viewbox="0 0 24 24" fill="none">
				<path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>
	</div>
</div>
